{
  "name": "CanvasImageComponent",
  "version": "1.0.0",
  "parameters": {
    "name": {
      "type": "string"
    },
    "stimulus": {
      "type": "string",
      "pretty_name": "Stimulus",
      "description": "Image URL or uploaded image path to draw into the trial canvas."
    },
    "height": {
      "type": "number",
      "default": null,
      "pretty_name": "Height"
    },
    "width": {
      "type": "number",
      "default": null,
      "pretty_name": "Width"
    },
    "maintain_aspect_ratio": {
      "type": "boolean",
      "default": true,
      "pretty_name": "Maintain Aspect Ratio"
    },
    "stimulus_onset": {
      "type": "number",
      "default": null,
      "pretty_name": "Stimulus Onset"
    },
    "stimulus_duration": {
      "type": "number",
      "default": null,
      "pretty_name": "Stimulus Duration"
    },
    "coordinates": {
      "type": "object",
      "default": "{ x: 0, y: 0 }",
      "pretty_name": "Coordinates"
    },
    "zIndex": {
      "type": "number",
      "default": 0,
      "pretty_name": "Z-Index"
    },
    "background_color": {
      "type": "string",
      "default": null,
      "pretty_name": "Background Color"
    },
    "clear_before_draw": {
      "type": "boolean",
      "default": true,
      "pretty_name": "Clear Before Draw"
    },
    "clear_on_offset": {
      "type": "boolean",
      "default": true,
      "pretty_name": "Clear On Offset"
    }
  }
}
