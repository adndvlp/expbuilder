{
  "name": "DynamicPlugin",
  "version": "1.0.0",
  "parameters": {
    "__canvasStyles": {
      "type": "object",
      "default": "{ width: 1024, height: 768 }"
    },
    "components": {
      "type": "object_array",
      "default": []
    },
    "response_components": {
      "type": "object_array",
      "default": []
    },
    "require_response": {
      "type": "boolean",
      "default": false
    },
    "trial_duration": {
      "type": "number",
      "default": null
    },
    "response_ends_trial": {
      "type": "boolean",
      "default": true
    },
    "dynamic_csv_diagnostics": {
      "type": "string",
      "default": "off",
      "pretty_name": "Dynamic CSV Audit Data",
      "description": "off = normal CSV only, summary = aggregate quality fields, full = benchmark/debug arrays"
    }
  },
  "data": {
    "rt": {
      "type": "number"
    }
  }
}