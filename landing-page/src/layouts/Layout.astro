<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/expbuilder/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>ExpBuilder - Build Psychological Experiments Without Limits</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@500;700;800&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
		/>
		<slot name="head" />
	</head>
	<body>
		<canvas id="particle-canvas" aria-hidden="true"></canvas>
		<div id="cursorGlow" class="cursor-glow" aria-hidden="true"></div>
		<div class="site-layer">
			<slot />
		</div>

		<script is:inline>
			(function initLandingParticles() {
				if (window.__expbuilderParticlesInit) return;
				window.__expbuilderParticlesInit = true;

				const canvas = document.getElementById("particle-canvas");
				const glow = document.getElementById("cursorGlow");
				if (!canvas) return;

				const ctx = canvas.getContext("2d");
				if (!ctx) return;

				let width = 0;
				let height = 0;
				let dpr = 1;
				let particles = [];
				let frameId = 0;
				let mouseX = null;
				let mouseY = null;

				const prefersReducedMotion = window.matchMedia(
					"(prefers-reduced-motion: reduce)",
				).matches;
				const coarsePointer = window.matchMedia("(pointer: coarse)").matches;
				const PARTICLE_COUNT = coarsePointer ? 48 : 88;
				const MAX_DISTANCE = coarsePointer ? 110 : 150;
				const MOUSE_RADIUS = coarsePointer ? 90 : 130;

				class Particle {
					constructor() {
						this.reset();
					}

					reset() {
						this.x = Math.random() * width;
						this.y = Math.random() * height;
						this.vx = (Math.random() - 0.5) * 0.35;
						this.vy = (Math.random() - 0.5) * 0.35;
						this.radius = Math.random() * 2 + 1;
						this.baseRadius = this.radius;
					}

					update() {
						this.x += this.vx;
						this.y += this.vy;

						if (this.x < 0 || this.x > width) {
							this.vx *= -1;
							this.x = Math.max(0, Math.min(this.x, width));
						}
						if (this.y < 0 || this.y > height) {
							this.vy *= -1;
							this.y = Math.max(0, Math.min(this.y, height));
						}

						this.vx *= 0.998;
						this.vy *= 0.998;

						if (Math.abs(this.vx) < 0.05) {
							this.vx += (Math.random() - 0.5) * 0.1;
						}
						if (Math.abs(this.vy) < 0.05) {
							this.vy += (Math.random() - 0.5) * 0.1;
						}

						if (mouseX !== null && mouseY !== null) {
							const dx = this.x - mouseX;
							const dy = this.y - mouseY;
							const dist = Math.hypot(dx, dy);

							if (dist < MOUSE_RADIUS) {
								const force = (MOUSE_RADIUS - dist) / MOUSE_RADIUS;
								const angle = Math.atan2(dy, dx);
								this.vx += Math.cos(angle) * force * 0.06;
								this.vy += Math.sin(angle) * force * 0.06;
								this.radius = this.baseRadius + force * 1.5;
							} else {
								this.radius = this.baseRadius;
							}
						} else {
							this.radius = this.baseRadius;
						}
					}

					draw() {
						let fill = "rgba(61, 146, 180, 0.6)";

						if (mouseX !== null && mouseY !== null) {
							const dist = Math.hypot(this.x - mouseX, this.y - mouseY);
							if (dist < MOUSE_RADIUS) {
								const boost = 1 - dist / MOUSE_RADIUS;
								fill = `rgba(212, 175, 55, ${0.55 + boost * 0.4})`;
							}
						}

						ctx.beginPath();
						ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
						ctx.fillStyle = fill;
						ctx.shadowColor = "rgba(61, 146, 180, 0.5)";
						ctx.shadowBlur = this.radius * 2;
						ctx.fill();
						ctx.shadowBlur = 0;
					}
				}

				function resize() {
					dpr = Math.min(window.devicePixelRatio || 1, 2);
					width = window.innerWidth;
					height = window.innerHeight;

					canvas.width = Math.floor(width * dpr);
					canvas.height = Math.floor(height * dpr);
					canvas.style.width = `${width}px`;
					canvas.style.height = `${height}px`;
					ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
				}

				function setupParticles() {
					particles = Array.from({ length: PARTICLE_COUNT }, () => new Particle());
				}

				function connectParticles() {
					for (let i = 0; i < particles.length; i += 1) {
						for (let j = i + 1; j < particles.length; j += 1) {
							const dx = particles[i].x - particles[j].x;
							const dy = particles[i].y - particles[j].y;
							const dist = Math.hypot(dx, dy);

							if (dist < MAX_DISTANCE) {
								const opacity = (1 - dist / MAX_DISTANCE) * 0.28;
								ctx.beginPath();
								ctx.moveTo(particles[i].x, particles[i].y);
								ctx.lineTo(particles[j].x, particles[j].y);
								ctx.strokeStyle = `rgba(61, 146, 180, ${opacity})`;
								ctx.lineWidth = 0.85;
								ctx.stroke();
							}
						}
					}
				}

				function draw() {
					ctx.clearRect(0, 0, width, height);
					connectParticles();
					particles.forEach((particle) => particle.draw());
				}

				function update() {
					particles.forEach((particle) => particle.update());
				}

				function loop() {
					update();
					draw();
					frameId = window.requestAnimationFrame(loop);
				}

				function updateGlow(x, y, visible) {
					if (!glow) return;
					glow.style.left = `${x}px`;
					glow.style.top = `${y}px`;
					glow.style.opacity = visible ? "1" : "0";
				}

				function onPointerMove(event) {
					mouseX = event.clientX;
					mouseY = event.clientY;
					updateGlow(event.clientX, event.clientY, true);
				}

				function onTouchMove(event) {
					if (!event.touches.length) return;
					const touch = event.touches[0];
					mouseX = touch.clientX;
					mouseY = touch.clientY;
				}

				function clearPointer() {
					mouseX = null;
					mouseY = null;
					if (glow) glow.style.opacity = "0";
				}

				function onResize() {
					resize();
					setupParticles();
					if (prefersReducedMotion) draw();
				}

				function onVisibilityChange() {
					if (prefersReducedMotion) return;
					if (document.hidden) {
						window.cancelAnimationFrame(frameId);
						frameId = 0;
					} else if (!frameId) {
						loop();
					}
				}

				resize();
				setupParticles();

				if (prefersReducedMotion) {
					draw();
				} else {
					loop();
				}

				window.addEventListener("resize", onResize, { passive: true });
				window.addEventListener("mousemove", onPointerMove, { passive: true });
				window.addEventListener("mouseleave", clearPointer, { passive: true });
				window.addEventListener("touchmove", onTouchMove, { passive: true });
				window.addEventListener("touchend", clearPointer, { passive: true });
				document.addEventListener("visibilitychange", onVisibilityChange);

				window.addEventListener("beforeunload", () => {
					window.cancelAnimationFrame(frameId);
					window.removeEventListener("resize", onResize);
					window.removeEventListener("mousemove", onPointerMove);
					window.removeEventListener("mouseleave", clearPointer);
					window.removeEventListener("touchmove", onTouchMove);
					window.removeEventListener("touchend", clearPointer);
					document.removeEventListener("visibilitychange", onVisibilityChange);
				});
			})();
		</script>
	</body>
</html>

<style is:global>
    :root {
        --primary-blue: #3d92b4;
        --dark-blue: #3e6879;
        --light-blue: #3e7d96;
        --gold: #d4af37;
        --light-gold: #f1c40f;
        --dark-gold: #b7950b;
        --neutral-dark: #1a1a2e;
        --neutral-light: #f8f9fa;
        --neutral-mid: #ddd;

        --bg-dark: #0f1014;
        --bg-card: rgba(28, 30, 38, 0.58);
        --bg-surface: rgba(23, 27, 35, 0.62);
        --text-main: #ffffff;
        --text-muted: #a0a7b9;
        --text-soft: #ccd2df;
        --card-border: rgba(255, 255, 255, 0.11);
        --accent-glow: rgba(61, 146, 180, 0.42);
        --gold-glow: rgba(212, 175, 55, 0.28);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        min-height: 100vh;
        font-family: "Inter", sans-serif;
        background:
            radial-gradient(circle at 8% 18%, rgba(61, 146, 180, 0.22), transparent 45%),
            radial-gradient(circle at 88% 12%, rgba(212, 175, 55, 0.18), transparent 40%),
            radial-gradient(circle at 50% 85%, rgba(61, 146, 180, 0.14), transparent 40%),
            var(--bg-dark);
        color: var(--text-main);
        overflow-x: hidden;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
    }

    body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background:
            repeating-linear-gradient(
                -35deg,
                rgba(255, 255, 255, 0.02) 0,
                rgba(255, 255, 255, 0.02) 1px,
                transparent 1px,
                transparent 10px
            );
        opacity: 0.45;
    }

    #particle-canvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
        opacity: 0.92;
    }

    .cursor-glow {
        position: fixed;
        width: 420px;
        height: 420px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 2;
        opacity: 0;
        transform: translate(-50%, -50%);
        transition: opacity 0.2s ease;
        background: radial-gradient(
            circle at center,
            rgba(61, 146, 180, 0.22) 0%,
            rgba(212, 175, 55, 0.08) 35%,
            transparent 70%
        );
        mix-blend-mode: screen;
    }

    .site-layer {
        position: relative;
        z-index: 5;
    }

    .container {
        width: min(100%, 1280px);
        margin: 0 auto;
        padding: 0 24px;
    }

    header,
    main,
    footer {
        position: relative;
        z-index: 6;
    }

    header {
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 25;
        background: rgba(12, 14, 19, 0.6);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 15px 30px -22px rgba(0, 0, 0, 0.85);
    }

    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        min-height: 76px;
        gap: 24px;
    }

    .logo {
        font-family: "Outfit", sans-serif;
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        background: linear-gradient(115deg, var(--primary-blue), var(--gold));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 0 26px rgba(61, 146, 180, 0.3);
    }

    .nav-links {
        list-style: none;
        display: flex;
        gap: 2.3rem;
        align-items: center;
    }

    .nav-links a {
        text-decoration: none;
        color: var(--text-soft);
        font-weight: 500;
        border-bottom: 2px solid transparent;
        padding-bottom: 0.26rem;
        transition: color 0.25s ease, border-color 0.25s ease;
    }

    .nav-links a:hover {
        color: var(--text-main);
        border-bottom-color: rgba(61, 146, 180, 0.75);
    }

    .btn-nav {
        padding: 0.44rem 1.2rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.26);
        background: rgba(255, 255, 255, 0.14);
        color: #f3f6ff !important;
        box-shadow: 0 10px 24px -18px rgba(0, 0, 0, 0.7);
        transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
    }

    .btn-nav:hover {
        transform: translateY(-2px);
        border-color: rgba(61, 146, 180, 0.6);
        background: rgba(61, 146, 180, 0.13);
    }

    .hero {
        min-height: calc(100vh - 76px);
        padding: 7.2rem 0 3rem;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        isolation: isolate;
    }

    .hero::before {
        content: "";
        position: absolute;
        inset: 12% 5% auto auto;
        width: min(540px, 48vw);
        height: min(540px, 50vw);
        border-radius: 50%;
        background: radial-gradient(circle, rgba(61, 146, 180, 0.16), transparent 70%);
        filter: blur(8px);
        z-index: -1;
        pointer-events: none;
    }

    .hero-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(2rem, 4.5vw, 4.5rem);
        align-items: center;
    }

    .hero-text {
        animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.43rem 1.12rem;
        margin-bottom: 1.25rem;
        border-radius: 999px;
        border: 1px solid rgba(61, 146, 180, 0.34);
        background: rgba(61, 146, 180, 0.15);
        color: #9cd1e5;
        font-size: 0.82rem;
        letter-spacing: 0.06em;
        font-weight: 600;
        box-shadow: 0 12px 24px -16px rgba(0, 0, 0, 0.6);
        text-transform: uppercase;
    }

    .hero-logo {
        width: clamp(82px, 9vw, 110px);
        height: auto;
        display: block;
        margin-bottom: 1.1rem;
        filter: drop-shadow(0 0 24px rgba(61, 146, 180, 0.4));
    }

    .hero h1 {
        font-family: "Outfit", sans-serif;
        font-size: clamp(2.2rem, 4.9vw, 4.2rem);
        line-height: 1.05;
        margin-bottom: 1rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        text-wrap: balance;
        background: linear-gradient(105deg, #ffffff 14%, #dcecff 52%, #fdeab3 94%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 0 28px rgba(61, 146, 180, 0.22);
    }

    .gradient-text {
        background: linear-gradient(135deg, var(--primary-blue), #6cc4e3, var(--gold));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .hero p {
        font-size: clamp(1.03rem, 1.5vw, 1.22rem);
        color: var(--text-soft);
        margin-bottom: 1.45rem;
        max-width: 580px;
    }

    .cta-group {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn {
        text-decoration: none;
        padding: 0.88rem 1.82rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: -0.01em;
        transition:
            transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
            box-shadow 0.3s ease,
            background 0.3s ease,
            border-color 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        border: 1px solid transparent;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    .btn-primary {
        color: #ffffff;
        background: linear-gradient(145deg, #f0ca5a, #cfa63b);
        border-color: rgba(255, 245, 214, 0.65);
        box-shadow:
            0 14px 30px -12px rgba(212, 175, 55, 0.6),
            0 0 0 1px rgba(255, 255, 255, 0.1) inset;
    }

    .btn-primary:hover {
        transform: translateY(-5px) scale(1.02);
        background: linear-gradient(145deg, #f5d36e, #d7af48);
        box-shadow:
            0 20px 36px -14px rgba(212, 175, 55, 0.7),
            0 0 0 1px rgba(255, 255, 255, 0.28) inset;
    }

    .btn-secondary {
        color: var(--text-main);
        border-color: rgba(255, 255, 255, 0.25);
        background: rgba(17, 22, 31, 0.45);
        box-shadow: 0 12px 28px -14px rgba(0, 0, 0, 0.7);
    }

    .btn-secondary:hover {
        transform: translateY(-4px);
        border-color: rgba(61, 146, 180, 0.68);
        background: rgba(61, 146, 180, 0.18);
    }

    .hero-visual {
        position: relative;
        animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.12s both;
    }

    .app-mockup {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        padding: 14px;
        border: 1px solid var(--card-border);
        background: var(--bg-surface);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        box-shadow:
            0 35px 50px -26px rgba(0, 0, 0, 0.75),
            0 0 0 1px rgba(61, 146, 180, 0.12) inset;
        transition: transform 0.35s ease, border-color 0.35s ease;
    }

    .app-mockup:hover {
        transform: translateY(-8px);
        border-color: rgba(61, 146, 180, 0.4);
    }

    .mockup-header {
        height: 44px;
        padding: 0 14px;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.04);
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: block;
    }

    .red {
        background: #ff5f56;
    }

    .yellow {
        background: #ffbd2e;
    }

    .green {
        background: #27c93f;
    }

    .mockup-body {
        position: relative;
        height: 350px;
        overflow: hidden;
        border-radius: 22px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background:
            linear-gradient(160deg, rgba(61, 146, 180, 0.16), transparent 42%),
            rgba(12, 16, 23, 0.9);
    }

    .mock-sidebar {
        position: absolute;
        left: 0;
        top: 0;
        width: 62px;
        height: 100%;
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
        z-index: 1;
    }

    .mock-canvas {
        position: relative;
        margin-left: 62px;
        height: 100%;
    }

    #rf-demo {
        width: 100%;
        height: 100%;
    }

    #rf-demo .react-flow__handle {
        background: linear-gradient(135deg, #ffe082 0%, #d4af37 100%) !important;
        width: 10px !important;
        height: 10px !important;
        border: 2px solid #fff !important;
        box-shadow: 0 0 8px #d4af37, 0 0 4px rgba(0,0,0,0.15) !important;
    }

    #rf-demo .react-flow__edge .react-flow__edge-path,
    #rf-demo .react-flow__edge .react-flow__edge-interaction {
        stroke: #d4af37 !important;
        stroke-width: 2 !important;
    }

    .glow-effect {
        position: absolute;
        inset: auto -20% -28% auto;
        width: 320px;
        height: 320px;
        border-radius: 50%;
        background: radial-gradient(circle, var(--accent-glow), transparent 72%);
        filter: blur(6px);
        z-index: -1;
        pointer-events: none;
    }

    .scroll-indicator {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        color: var(--text-muted);
        font-size: 1.45rem;
        animation: bounce 2.3s infinite;
    }

    .features {
        padding: 4rem 0 6.2rem;
        position: relative;
    }

    .section-title,
    .download-content h2 {
        font-family: "Outfit", sans-serif;
        text-align: center;
        font-size: clamp(2rem, 4vw, 2.9rem);
        margin-bottom: 0.9rem;
        letter-spacing: -0.025em;
        background: linear-gradient(110deg, #ffffff, #d2e6ef 45%, #f4df9f);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.7rem;
        margin-top: 2.6rem;
    }

    .card,
    .dl-card {
        position: relative;
        background: var(--bg-card);
        border-radius: 32px;
        border: 1px solid var(--card-border);
        padding: 2rem 1.7rem;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        box-shadow:
            0 28px 44px -24px rgba(0, 0, 0, 0.75),
            0 0 0 1px rgba(61, 146, 180, 0.08) inset;
        transition:
            transform 0.35s ease,
            border-color 0.35s ease,
            background 0.35s ease,
            box-shadow 0.35s ease;
    }

    .card:hover,
    .dl-card:hover {
        --card-lift: -8px;
        transform: translateY(var(--card-lift));
        background: rgba(31, 36, 46, 0.78);
        border-color: rgba(61, 146, 180, 0.45);
        box-shadow:
            0 34px 48px -20px rgba(0, 0, 0, 0.85),
            0 0 0 1px rgba(61, 146, 180, 0.24) inset;
    }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(212, 175, 55, 0.16);
        color: var(--gold);
        font-size: 1.45rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.3rem;
        transition: transform 0.25s ease, background 0.25s ease;
    }

    .card:hover .icon-box {
        transform: scale(1.03);
        background: rgba(212, 175, 55, 0.25);
    }

    .card h3,
    .dl-card h3 {
        font-family: "Outfit", sans-serif;
        font-size: 1.45rem;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin-bottom: 0.65rem;
