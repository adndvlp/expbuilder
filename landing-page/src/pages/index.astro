---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header>
        <nav class="container">
            <div class="logo">ExpBuilder</div>
            <ul class="nav-links">
                <li><a href="#features">Features</a></li>
                <li><a href="#download" class="btn-nav">Download</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <section class="hero">
            <div class="container hero-content">
                <div class="hero-text">
                    <img src="/expbuilder/logo.png" alt="ExpBuilder Logo" class="hero-logo" />
                    <span id="version-badge" class="badge">LATEST RELEASE</span>
                    <h1>Design <span class="gradient-text">Professional</span> Experiments in Minutes</h1>
                    <p>The ultimate tool for researchers. Intuitive visual interface, no-code, unlimited power. JsPsych compatible and future-ready.</p>
                    <div class="cta-group">
                        <a href="#download" class="btn btn-primary"><i class="fas fa-download"></i> Download</a>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="app-mockup">
                        <div class="mockup-header">
                            <span class="dot red"></span>
                            <span class="dot yellow"></span>
                            <span class="dot green"></span>
                        </div>
                        <div class="mockup-body">
                            <!-- Abstract representation of the UI -->
                            <div class="mock-sidebar"></div>
                            <div class="mock-canvas">
                                <div class="mock-node n1"></div>
                                <div class="mock-node n2"></div>
                                <div class="mock-node n3"></div>
                                <svg class="mock-lines">
                                    <path d="M50 50 L150 150" stroke="#d4af37" stroke-width="2"/>
                                </svg>
                            </div>
                        </div>
                    </div>
                    <div class="glow-effect"></div>
                </div>
            </div>
            
            <div class="scroll-indicator">
                <i class="fas fa-chevron-down"></i>
            </div>
        </section>

        <section id="features" class="features">
            <div class="container">
                <h2 class="section-title">Empower Your Research</h2>
                <div class="cards-grid">
                    <div class="card">
                        <div class="icon-box">
                            <i class="fas fa-hand-holding-dollar"></i>
                        </div>
                        <h3>100% Free & Open Source</h3>
                        <p>No subscriptions, no per-participant fees. Host experiments on your own terms using GitHub Pages or any static server.</p>
                    </div>
                    <div class="card">
                        <div class="icon-box">
                            <i class="fas fa-database"></i>
                        </div>
                        <h3>Data Sovereignty</h3>
                        <p>Your data, your infrastructure. Connect directly to your own Firebase, OSF, Google Drive, or Dropbox. Compliance made easy.</p>
                    </div>
                    <div class="card">
                        <div class="icon-box">
                            <i class="fas fa-shapes"></i>
                        </div>
                        <h3>Visual & Code Hybrid</h3>
                        <p>Start with a drag-and-drop canvas. Drop down to code when you need complex logic. The best of both worlds.</p>
                    </div>
                    <div class="card">
                        <div class="icon-box">
                            <i class="fas fa-globe"></i>
                        </div>
                        <h3>Simplicity for Everyone</h3>
                        <p>Built on jsPsych. Runs in any browser. Includes basic templates to help you understand the flow and structure of your experiments.</p>
                    </div>
                    <div class="card">
                        <div class="icon-box">
                            <i class="fas fa-stopwatch"></i>
                        </div>
                        <h3>Standard Precision</h3>
                        <p>Reliable graphical timing suitable for web-based cognitive tasks. Similar to jsPsych, optimized for modern browser performance.</p>
                    </div>
                    <div class="card">
                        <div class="icon-box">
                            <i class="fas fa-laptop-code"></i>
                        </div>
                        <h3>Offline-Capable</h3>
                        <p>Design offline with our desktop app. Export standard HTML/JS packages ready for deployment.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Removed separate Donate section to move to footer as requested -->

        <section id="download" class="download">
            <div class="container download-content">
                <h2>Start Creating Today</h2>
                <p>Join the community of researchers already using ExpBuilder.</p>
                <div class="download-cards">
                    <div class="dl-card mac">
                        <i class="fab fa-apple dl-icon"></i>
                        <h3>macOS</h3>
                        <div class="dl-arch-group" data-os="mac" data-arch="arm64">
                            <span class="arch-label">Apple Silicon</span>
                            <div class="btn-group">
                                <a id="dl-mac-arm-dmg" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-primary">.dmg</a>
                                <a id="dl-mac-arm-zip" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-secondary">.zip</a>
                            </div>
                        </div>
                        <div class="dl-arch-group" data-os="mac" data-arch="x64">
                            <span class="arch-label">Intel (x64)</span>
                            <div class="btn-group">
                                <a id="dl-mac-intel-dmg" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-primary">.dmg</a>
                                <a id="dl-mac-intel-zip" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-secondary">.zip</a>
                            </div>
                        </div>
                    </div>
                    <div class="dl-card win">
                        <i class="fab fa-windows dl-icon"></i>
                        <h3>Windows</h3>
                        <div class="dl-arch-group" data-os="windows" data-arch="x64">
                            <span class="arch-label">x64 (AMD64)</span>
                            <div class="btn-group">
                                <a id="dl-win-exe" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-primary"><i class="fas fa-download"></i> .exe</a>
                                <a id="dl-win-zip" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-secondary">.zip</a>
                            </div>
                        </div>
                    </div>
                    <div class="dl-card linux">
                        <i class="fab fa-linux dl-icon"></i>
                        <h3>Linux</h3>
                        <div class="dl-arch-group" data-os="linux" data-arch="arm64">
                            <span class="arch-label">ARM64 (.deb)</span>
                            <div class="btn-group">
                                <a id="dl-linux-deb-arm" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-primary">.deb</a>
                            </div>
                        </div>
                        <div class="dl-arch-group" data-os="linux" data-arch="x64">
                            <span class="arch-label">AMD64 (.deb / .rpm)</span>
                            <div class="btn-group">
                                <a id="dl-linux-deb-amd" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-secondary">.deb</a>
                                <a id="dl-linux-rpm-amd" href="https://github.com/adndvlp/expbuilder/releases/latest" class="btn btn-secondary">.rpm</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container footer-content">
            <div class="footer-columns">
                <div class="footer-col brand-col">
                    <div class="footer-logo">ExpBuilder</div>
                    <p class="copyright-text">&copy; <span id="year"></span> Laboratorio de Psicolingüística, Fac. Psicología, UNAM.</p>
                    <p class="license-text">Open Source Project under MIT License.</p>
                </div>
                
                <div class="footer-col links-col">
                    <h4>Institutional Home</h4>
                    <div class="inst-logos" style="display: flex; gap: 20px; align-items: center; margin-top: 10px;">
                        <a href="https://www.unam.mx/" target="_blank" title="Universidad Nacional Autónoma de México">
                            <img src="/expbuilder/unam-logo.svg" alt="UNAM" class="inst-logo unam-filter" />
                        </a>
                        <a href="https://www.psicologia.unam.mx/" target="_blank" title="Facultad de Psicología">
                            <img src="/expbuilder/fp%20white.png" alt="Facultad de Psicología" class="inst-logo" />
                        </a>
                        <a href="https://www.labpsicolinguistica.psicol.unam.mx/" target="_blank" title="Laboratorio de Psicolingüística">
                            <img src="/expbuilder/lab.png" alt="Laboratorio de Psicolingüística" class="inst-logo" />
                        </a>
                    </div>
                </div>

                <div class="footer-col support-col">
                    <h4>Support Us</h4>
                    <p>Help us maintain these tools for open science.</p>
                    <a href="https://opencollective.com/" target="_blank" class="btn-footer-action"><i class="fas fa-heart"></i> Donate on Open Collective</a>
                </div>

                <div class="footer-col contact-col">
                    <h4>Developer Contact</h4>
                    <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 10px;">Andrés Pacheco Fabián</p>
                    <div class="socials">
                        <a href="https://github.com/adndvlp" target="_blank" title="My GitHub Profile"><i class="fab fa-github"></i></a>
                        <a href="https://www.linkedin.com/in/" target="_blank" title="My LinkedIn Profile"><i class="fab fa-linkedin"></i></a>
                        <a href="mailto:andngdv.lpr@gmail.com" title="Email Me"><i class="fas fa-envelope"></i></a>
                    </div>
                    <a href="https://github.com/adndvlp/expbuilder" target="_blank" class="project-repo-link"><i class="fas fa-code-branch"></i> View Project Repo</a>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Helper
        function setHref(id, url) {
            const el = document.getElementById(id);
            if(el) el.href = url;
        }

        // Set dynamic year
        document.getElementById('year').textContent = new Date().getFullYear();

        // OS + architecture recommendation logic
        function detectOS() {
            const userAgent = window.navigator.userAgent;
            const platform = window.navigator.platform;

            if (/Mac|iPhone|iPad|iPod/i.test(platform)) return 'mac';
            if (/Win/i.test(platform)) return 'windows';
            if (/Android/i.test(userAgent)) return 'android';
            if (/Linux/i.test(platform)) return 'linux';
            return null;
        }

        function normalizeArch(rawValue) {
            if (!rawValue) return null;
            const value = String(rawValue).toLowerCase();

            if (/(arm64|aarch64|armv8)/.test(value)) return 'arm64';
            if (/(x86_64|x64|amd64|wow64|win64|x86-64)/.test(value)) return 'x64';
            if (/arm/.test(value)) return 'arm64';
            if (/(x86|i386|i686|ia32)/.test(value)) return 'x64';
            return null;
        }

        function detectWebGLRenderer() {
            try {
                const canvas = document.createElement('canvas');
                const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
                if (!gl) return '';

                const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
                if (!debugInfo) return '';

                const renderer = gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL);
                return renderer ? String(renderer).toLowerCase() : '';
            } catch (_error) {
                return '';
            }
        }

        async function detectArch(os) {
            const { userAgent, platform, userAgentData } = window.navigator;
            const directMatch = normalizeArch(`${userAgent} ${platform}`);
            if (directMatch) return directMatch;

            if (userAgentData) {
                const lowEntropyArch = normalizeArch(userAgentData.architecture);
                if (lowEntropyArch) return lowEntropyArch;

                if (typeof userAgentData.getHighEntropyValues === 'function') {
                    try {
                        const hints = await userAgentData.getHighEntropyValues(['architecture', 'bitness']);
                        const hintArch = normalizeArch(`${hints.architecture || ''} ${hints.bitness || ''}`);
                        if (hintArch) return hintArch;
                    } catch (_error) {
                        // Ignore and continue with fallback heuristics.
                    }
                }
            }

            const renderer = detectWebGLRenderer();
            const rendererArch = normalizeArch(renderer);
            if (rendererArch) return rendererArch;

            if (os === 'mac') {
                if (renderer.includes('apple') && !renderer.includes('intel')) return 'arm64';
                if (renderer.includes('intel') || renderer.includes('amd') || renderer.includes('radeon')) return 'x64';
            }

            if (os === 'windows') return 'x64';
            return null;
        }

        function getOsLabel(os) {
            const labels = {
                mac: 'macOS',
                windows: 'Windows',
                linux: 'Linux'
            };
            return labels[os] || 'Your platform';
        }

        function getArchLabel(os, arch) {
            const map = {
                mac: {
                    arm64: 'Apple Silicon (ARM64)',
                    x64: 'Intel / AMD (x64)'
                },
                linux: {
                    arm64: 'ARM64',
                    x64: 'AMD64 / x64'
                },
                windows: {
                    x64: 'AMD64 / x64'
                }
            };

            return map[os] && map[os][arch] ? map[os][arch] : null;
        }

        function markRecommendedDownload(os, arch) {
            const cardSelector = {
                mac: '.dl-card.mac',
                windows: '.dl-card.win',
                linux: '.dl-card.linux'
            };

            const card = document.querySelector(cardSelector[os]);
            if (!card) return;

            card.classList.add('recommended');
            const oldBadge = card.querySelector('.rec-badge');
            if (oldBadge) oldBadge.remove();

            const badge = document.createElement('div');
            badge.className = 'rec-badge';

            const archLabel = getArchLabel(os, arch);
            badge.textContent = archLabel
                ? `Recommended: ${getOsLabel(os)} · ${archLabel}`
                : `Recommended: ${getOsLabel(os)}`;

            card.appendChild(badge);

            if (!arch) return;

            const archGroups = document.querySelectorAll(`.dl-arch-group[data-os="${os}"][data-arch="${arch}"]`);
            archGroups.forEach((group) => {
                group.classList.add('arch-recommended');
                group.querySelectorAll('.btn').forEach((btn) => {
                    btn.classList.add('btn-recommended-arch');
                });
            });
        }

        (async () => {
            const os = detectOS();
            if (!os || os === 'android') return;

            const arch = await detectArch(os);
            markRecommendedDownload(os, arch);
        })();

        // Simple intersection observer
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.card, .dl-card, .hero-text').forEach((el) => {
            el.classList.add('fade-in');
            observer.observe(el);
        });

        // Dynamic Release Fetcher
        fetch('https://api.github.com/repos/adndvlp/expbuilder/releases/latest')
            .then(res => res.json())
            .then(data => {
                // Update Version Badge
                if(data.tag_name) {
                    const badge = document.getElementById('version-badge');
                    if(badge) badge.textContent = `NEW VERSION ${data.tag_name}`;
                }

                if(data.assets && data.assets.length > 0) {
                    const a = data.assets;

                    // macOS
                    const macArmDmg    = a.find(f => f.name.endsWith('.dmg') && f.name.includes('arm64'));
                    const macIntelDmg  = a.find(f => f.name.endsWith('.dmg') && !f.name.includes('arm64'));
                    const macArmZip    = a.find(f => f.name.endsWith('.zip') && f.name.toLowerCase().includes('mac') && f.name.includes('arm64'));
                    const macIntelZip  = a.find(f => f.name.endsWith('.zip') && f.name.toLowerCase().includes('mac') && !f.name.includes('arm64'));

                    if(macArmDmg)   setHref('dl-mac-arm-dmg',   macArmDmg.browser_download_url);
                    if(macArmZip)   setHref('dl-mac-arm-zip',   macArmZip.browser_download_url);
                    if(macIntelDmg) setHref('dl-mac-intel-dmg', macIntelDmg.browser_download_url);
                    if(macIntelZip) setHref('dl-mac-intel-zip', macIntelZip.browser_download_url);

                    // Windows
                    const winExe = a.find(f => f.name.endsWith('.exe'));
                    const winZip = a.find(f => f.name.endsWith('.zip') && f.name.toLowerCase().includes('win'));

                    if(winExe) setHref('dl-win-exe', winExe.browser_download_url);
                    if(winZip) setHref('dl-win-zip', winZip.browser_download_url);

                    // Linux
                    const debArm = a.find(f => f.name.endsWith('.deb') && f.name.includes('arm64'));
                    const debAmd = a.find(f => f.name.endsWith('.deb') && (f.name.includes('amd64') || f.name.includes('x86_64') || !f.name.includes('arm64')));
                    const rpmAmd = a.find(f => f.name.endsWith('.rpm'));

                    if(debArm) setHref('dl-linux-deb-arm', debArm.browser_download_url);
                    if(debAmd) setHref('dl-linux-deb-amd', debAmd.browser_download_url);
                    if(rpmAmd) setHref('dl-linux-rpm-amd', rpmAmd.browser_download_url);
                }
            })
            .catch(e => console.log('Could not fetch latest release, using default link'));
    </script>
</Layout>
